[Unit]
Description=Hazel Daily Digest Generator
After=network.target

[Service]
Type=oneshot
User=openclaw
ExecStart=/usr/bin/curl -s -X POST http://127.0.0.1:8700/api/digest/generate -H "X-Webhook-Secret: %i" -H "Content-Type: application/json"
TimeoutStartSec=30

[Install]
WantedBy=multi-user.target
